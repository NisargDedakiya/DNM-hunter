#!/usr/bin/env bash
# =============================================================================
# starthunt — one command to start the WHOLE DNM-Hunter platform.
#
# This is a friendly wrapper around ./nisarghunter.sh (the real orchestrator).
# It brings up the entire stack, not just the frontend/backend:
#
#     postgres          relational DB (users, scans, findings, subscriptions)
#     neo4j             knowledge graph (attack chains, entities)
#     docker-broker     controlled Docker API broker for scanner containers
#     recon-orchestrator  recon pipeline coordinator
#     kali-sandbox      isolated tooling sandbox
#     agent             the Python AI agent + scanner suite (nh-scan, web_attack…)
#     webapp            the Next.js frontend + API  →  http://localhost:3000
#
#   Scanner tool images (recon, vuln-scanner, github-hunter, trufflehog, baddns,
#   ai-attack-surface, wcvs, codefix-sandbox) are BUILD-ON-DEMAND — they run when
#   a scan needs them, not as always-on services.
#
# Usage:
#     ./starthunt                 start everything (installs on first run, else up)
#     ./starthunt dev             start in dev mode (hot-reload, source mounts)
#     ./starthunt stop            stop the stack (containers down, data kept)
#     ./starthunt status          show what's running
#     ./starthunt logs [service]  tail logs (all, or one service)
#     ./starthunt restart         stop then start
#     ./starthunt update          pull latest + rebuild changed services
#     ./starthunt reinstall       force a full (re)install
#     ./starthunt help
# =============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'
info()    { echo -e "${CYAN}[starthunt]${NC} $*"; }
ok()      { echo -e "${GREEN}[ok]${NC} $*"; }
warn()    { echo -e "${YELLOW}[warn]${NC} $*"; }
die()     { echo -e "${RED}[error]${NC} $*" >&2; exit 1; }

WEBAPP_PORT="${WEBAPP_PORT:-3000}"
AGENT_PORT="${AGENT_PORT:-8090}"

banner() {
  echo -e "${RED}${BOLD}"
  echo "  ____  _   _ __  __      _   _ _   _ _   _ _____ _____ ____  "
  echo " |  _ \\| \\ | |  \\/  |    | | | | | | | \\ | |_   _| ____|  _ \\ "
  echo " | | | |  \\| | |\\/| |____| |_| | | | |  \\| | | | |  _| | |_) |"
  echo " | |_| | |\\  | |  | |____|  _  | |_| | |\\  | | | | |___|  _ < "
  echo " |____/|_| \\_|_|  |_|    |_| |_|\\___/|_| \\_| |_| |_____|_| \\_\\"
  echo -e "${NC}   AI-powered vulnerability research platform\n"
}

# ── preflight ────────────────────────────────────────────────────────────────
preflight() {
  command -v docker >/dev/null 2>&1 || die "Docker is not installed. Install Docker Desktop (Windows/macOS) or Docker Engine (Linux) and re-run."
  if ! docker info >/dev/null 2>&1; then
    die "The Docker daemon isn't running. Start Docker Desktop (or 'sudo systemctl start docker') and re-run."
  fi
  docker compose version >/dev/null 2>&1 || die "'docker compose' (v2) is required. Update Docker to a recent version."
  [[ -f "$SCRIPT_DIR/nisarghunter.sh" ]] || die "nisarghunter.sh not found next to starthunt — run this from the repo root."
}

# Create .env from the template on first run so the stack can boot locally.
ensure_env() {
  if [[ ! -f "$SCRIPT_DIR/.env" ]]; then
    if [[ -f "$SCRIPT_DIR/.env.example" ]]; then
      cp "$SCRIPT_DIR/.env.example" "$SCRIPT_DIR/.env"
      warn "No .env found — created one from .env.example."
      warn "Defaults are fine for local use; add AI provider keys later in the app (Settings → AI models) or edit .env."
    else
      warn "No .env or .env.example found; continuing with compose defaults."
    fi
  fi
}

# First run if no DNM-Hunter container has ever been created.
is_first_run() {
  [[ -z "$(docker ps -a --filter 'name=nisarghunter-' -q 2>/dev/null)" ]]
}

wait_for_web() {
  command -v curl >/dev/null 2>&1 || return 0   # can't probe without curl; assume it's coming up
  info "Waiting for the web app to come up on http://localhost:${WEBAPP_PORT} ..."
  for _ in $(seq 1 60); do
    if curl -fsS -o /dev/null "http://localhost:${WEBAPP_PORT}" 2>/dev/null; then
      return 0
    fi
    sleep 2
  done
  return 1
}

print_ready() {
  echo
  ok "DNM-Hunter is up."
  echo -e "   ${BOLD}Web app${NC}   →  ${CYAN}http://localhost:${WEBAPP_PORT}${NC}"
  echo -e "   ${BOLD}AI agent${NC}  →  http://localhost:${AGENT_PORT}"
  echo
  echo -e "   Logs:    ${CYAN}./starthunt logs${NC}        Status: ${CYAN}./starthunt status${NC}"
  echo -e "   Stop:    ${CYAN}./starthunt stop${NC}"
  echo
}

start_stack() {
  ensure_env
  if is_first_run; then
    info "First run detected — installing the full stack (this builds images and can take a while)…"
    ./nisarghunter.sh install
  else
    info "Starting the full stack…"
    ./nisarghunter.sh up
  fi
  if wait_for_web; then
    print_ready
  else
    warn "Web app didn't answer yet — it may still be building. Check: ./starthunt logs webapp"
    print_ready
  fi
}

usage() { sed -n '3,40p' "$0" | sed 's/^# \{0,1\}//'; }

# ── dispatch ─────────────────────────────────────────────────────────────────
cmd="${1:-up}"
case "$cmd" in
  up|start|"")
    banner; preflight; start_stack
    ;;
  dev)
    banner; preflight; ensure_env
    info "Starting in dev mode (hot-reload)…"
    ./nisarghunter.sh up dev
    wait_for_web && print_ready || { warn "Still starting — ./starthunt logs webapp"; print_ready; }
    ;;
  stop|down)
    preflight; info "Stopping the stack (data volumes are kept)…"
    ./nisarghunter.sh down; ok "Stopped."
    ;;
  restart)
    preflight; ./nisarghunter.sh down || true; banner; start_stack
    ;;
  status)
    preflight; ./nisarghunter.sh status
    ;;
  logs)
    preflight; shift || true
    if [[ -n "${1:-}" ]]; then docker compose logs -f "$1"; else docker compose logs -f; fi
    ;;
  update)
    preflight; ./nisarghunter.sh update
    ;;
  reinstall)
    preflight; banner; ensure_env
    info "Forcing a full (re)install…"
    ./nisarghunter.sh install
    wait_for_web && print_ready || print_ready
    ;;
  help|-h|--help)
    banner; usage
    ;;
  *)
    die "Unknown command: $cmd  (try: ./starthunt help)"
    ;;
esac
